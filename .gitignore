# =============================================================================
# ZJSSO - Git Ignore Configuration
# =============================================================================
# 参考: https://github.com/github/gitignore
# =============================================================================

# ------------------------------
# 环境变量文件（敏感信息）
# ------------------------------
.env
.env.local
.env.*.local

# ------------------------------
# Node.js 依赖（根目录和前端）
# ------------------------------
node_modules/
frontend/node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml
frontend/package-lock.json
frontend/yarn.lock
frontend/pnpm-lock.yaml

# ------------------------------
# 前端构建产物
# ------------------------------
frontend/dist/
frontend/.nuxt/
frontend/.output/
*.timestamp-*.mjs

# ------------------------------
# 用户上传文件
# ------------------------------
uploads/
!uploads/.gitkeep

# ------------------------------
# 日志文件
# ------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ------------------------------
# IDE / Editor
# ------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# ------------------------------
# 操作系统文件
# ------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------
# 临时文件
# ------------------------------
*.tmp
*.temp

# ------------------------------
# 测试和覆盖率
# ------------------------------
coverage/
.nyc_output/

# ------------------------------
# 测试客户端程序
# ------------------------------
test-client/

# ------------------------------
# Docker
# ------------------------------
docker-compose.override.yml

# ------------------------------
# 构建工具缓存
# ------------------------------
.eslintcache
.parcel-cache/
.cache/
.next/

# ------------------------------
# 数据库备份
# ------------------------------
*.sql
!src/database/*.sql
*.bak
*.dump
/漏洞
deploy/nginx.conf
