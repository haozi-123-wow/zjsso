# =============================================================================
# ZJSSO (耗子 SSO 单点登录系统) - 环境变量示例文件
# =============================================================================
# 使用方法：
#   1. 复制此文件为 .env：cp .env.example .env
#   2. 修改 .env 中的实际配置值（密码、密钥等）
#   3. 确保 .env 不被提交到版本控制系统
# =============================================================================

# ----- 服务基础配置 -----
APP_PORT=6873              # 后端服务监听端口
APP_HOST=localhost          # 后端服务监听地址（0.0.0.0 表示监听所有网卡）

# ----- 数据库配置（MySQL） -----
DB_HOST=127.0.0.1          # 数据库主机地址
DB_PORT=3306               # 数据库端口
DB_USER=root               # 数据库用户名
DB_PASSWORD=               # 数据库密码
DB_NAME=zjsso              # 数据库名称

# ----- Redis 配置 -----
REDIS_HOST=127.0.0.1       # Redis 主机地址
REDIS_PORT=6379            # Redis 端口
REDIS_PASSWORD=            # Redis 密码（无密码则留空）

# ----- JWT 令牌配置 -----
JWT_SECRET=                # JWT 签名密钥（请改为随机字符串以保证安全）
JWT_EXPIRES_IN=3600        # access_token 有效期（秒），3600 = 1小时
REFRESH_TOKEN_EXPIRES_IN=604800  # refresh_token 有效期（秒），604800 = 7天

# ----- 会话配置 -----
SESSION_MODE=stateful      # 会话模式：stateless | stateful
SESSION_SECRET=            # 会话加密密钥
SESSION_EXPIRES_IN=86400   # 会话有效期（秒），86400 = 1天

# ----- OIDC 发行人配置 -----
ISSUER=http://localhost:6873

# ----- 前端地址配置 -----
# 邮件中的激活/重置密码链接会使用此地址。默认与 ISSUER 相同
FRONTEND_URL=http://localhost:6873

# =============================================================================
# 极验 Geetest v4 行为验证
# =============================================================================
GEETEST_CAPTCHA_ID=        # 极验 captchaId（从极验后台获取）
GEETEST_CAPTCHA_KEY=       # 极验 captchaKey（从极验后台获取）
GEETEST_API_URL=http://gcaptcha4.geetest.com

# =============================================================================
# 阿里云邮件推送 DirectMail
# =============================================================================
ALIYUN_DM_ACCESS_KEY_ID=              # 阿里云 AccessKey ID
ALIYUN_DM_ACCESS_KEY_SECRET=          # 阿里云 AccessKey Secret
ALIYUN_DM_ACCOUNT_NAME=               # 发信地址
ALIYUN_DM_FROM_ALIAS=                 # 发信人显示名称
ALIYUN_DM_REGION=cn-hangzhou          # 阿里云服务区域
EMAIL_VERIFICATION_EXPIRES=3600        # 邮件验证码有效期（秒）

# =============================================================================
# IP 归属地查询 API（apihz.cn）
# =============================================================================
IP_API_ID=                 # API ID（https://www.apihz.cn/）
IP_API_KEY=                # API Key

# =============================================================================
# WebAuthn 通行密钥（Passkey）
# =============================================================================
WEBAUTHN_RP_ID=localhost               # 依赖方标识（不含协议和端口）
WEBAUTHN_RP_NAME=ZJSSO System          # 依赖方显示名称
WEBAUTHN_ALLOWED_ORIGINS=http://localhost,http://localhost:5173,http://localhost:4173

# =============================================================================
# GitHub 第三方登录
# =============================================================================
GITHUB_CLIENT_ID=                                         # GitHub OAuth App Client ID
GITHUB_CLIENT_SECRET=                                     # GitHub OAuth App Client Secret
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/social/github/callback

# =============================================================================
# QQ 第三方登录
# =============================================================================
QQ_APP_ID=                                                # QQ 互联 APP ID
QQ_APP_KEY=                                               # QQ 互联 APP Key
QQ_CALLBACK_URL=http://localhost:3000/api/auth/social/qq/callback

# =============================================================================
# Google 第三方登录
# =============================================================================
GOOGLE_CLIENT_ID=                                            # Google OAuth 2.0 Client ID
GOOGLE_CLIENT_SECRET=                                        # Google OAuth 2.0 Client Secret
GOOGLE_CALLBACK_URL=http://localhost:6873/api/auth/social/google/callback

# =============================================================================
# 腾讯云 COS 对象存储（头像直传）
# =============================================================================
COS_SECRET_ID=             # 腾讯云 SecretId
COS_SECRET_KEY=            # 腾讯云 SecretKey
COS_BUCKET=                # COS 存储桶名称
COS_REGION=ap-guangzhou    # COS 存储桶地域
COS_CUSTOM_DOMAIN=         # 可选，CDN 加速域名

# =============================================================================
# SOCKS5 代理（用于 Google 登录等需要代理的场景）
# =============================================================================
SOCKS5_PROXY_HOST=                                           # SOCKS5 代理主机地址
SOCKS5_PROXY_PORT=1080                                       # SOCKS5 代理端口
SOCKS5_PROXY_USERNAME=                                       # SOCKS5 代理用户名（无需认证则留空）
SOCKS5_PROXY_PASSWORD=                                       # SOCKS5 代理密码（无需认证则留空）
